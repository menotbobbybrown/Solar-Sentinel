    {
        "id": "eva_map_processor",
        "type": "function",
        "z": "flow_eva_map",
        "name": "Process EVA Map",
        "func": "const map = msg.payload;\n\n// Calculate stats\nlet totalPower = 0;\nlet phantomCount = 0;\nlet shiftableCount = 0;\nlet luxuryCount = 0;\nlet criticalCount = 0;\n\nObject.values(map.nodes || {}).forEach(node => {\n    totalPower += node.last_power || 0;\n    const priority = node.priority || 'UNKNOWN';\n    if (priority === 'PHANTOM') phantomCount++;\n    else if (priority === 'SHIFTABLE') shiftableCount++;\n    else if (priority === 'LUXURY') luxuryCount++;\n    else if (priority === 'CRITICAL') criticalCount++;\n});\n\n// Store for different displays\nmsg.nodes = map.nodes;\nmsg.system = map.system;\nmsg.phantomTotal = map.phantom_total || 0;\nmsg.optimalWindow = map.optimal_window;\nmsg.recommendations = map.recommendations || [];\nmsg.totalPower = totalPower;\nmsg.priorityCounts = { phantom: phantomCount, shiftable: shiftableCount, luxury: luxuryCount, critical: criticalCount };\n\nreturn msg;",
        "outputs": "1",
        "timeout": 0,
        "x": 340,
        "y": 80,
        "wires": [["ui_template_eva_map", "ui_chart_priority", "ui_stat_phantom", "ui_stat_power"]]
    },
    {
        "id": "ui_template_eva_map",
        "type": "ui_template",
        "z": "flow_eva_map",
        "group": "ui_group_eva_main",
        "name": "Energy Map View",
        "order": 1,
        "width": "12",
        "height": "12",
        "format": "<div id=\"eva-map\" style=\"background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #eee; padding: 20px; border-radius: 15px; font-family: 'Segoe UI', sans-serif; min-height: 400px;\">\n    <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #333; padding-bottom: 15px;\">\n        <h2 style=\"margin: 0; color: #00ff88;\">⚡ EVA ENERGY MAP</h2>\n        <div style=\"text-align: right;\">\n            <div style=\"font-size: 12px; color: #888;\">Last Update</div>\n            <div>{{payload.timestamp | date:'HH:mm:ss'}}</div>\n        </div>\n    </div>\n    \n    <div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 20px;\">\n        <div style=\"background: rgba(0,255,136,0.1); padding: 15px; border-radius: 10px; text-align: center;\">\n            <div style=\"font-size: 24px; font-weight: bold; color: #00ff88;\">{{payload.system.soc}}%</div>\n            <div style=\"font-size: 11px; color: #888;\">Battery SOC</div>\n        </div>\n        <div style=\"background: rgba(255,200,0,0.1); padding: 15px; border-radius: 10px; text-align: center;\">\n            <div style=\"font-size: 24px; font-weight: bold; color: #ffc800;\">{{payload.system.tier}}</div>\n            <div style=\"font-size: 11px; color: #888;\">Guard Tier</div>\n        </div>\n        <div style=\"background: rgba(0,150,255,0.1); padding: 15px; border-radius: 10px; text-align: center;\">\n            <div style=\"font-size: 24px; font-weight: bold; color: #0096ff;\">{{payload.system.pv_watts}}W</div>\n            <div style=\"font-size: 11px; color: #888;\">Solar Power</div>\n        </div>\n        <div style=\"background: rgba(255,100,100,0.1); padding: 15px; border-radius: 10px; text-align: center;\">\n            <div style=\"font-size: 24px; font-weight: bold; color: #ff6464;\">{{payload.phantom_total || 0}}</div>\n            <div style=\"font-size: 11px; color: #888;\">Phantom Cuts</div>\n        </div>\n    </div>\n    \n    <div style=\"margin-bottom: 20px;\">\n        <h3 style=\"color: #888; font-size: 14px; margin-bottom: 10px;\">DEVICE STATUS</h3>\n        <table style=\"width: 100%; border-collapse: collapse;\">\n            <tr style=\"border-bottom: 1px solid #333; color: #888;\">\n                <th style=\"padding: 8px; text-align: left;\">Device</th>\n                <th style=\"padding: 8px; text-align: center;\">Power</th>\n                <th style=\"padding: 8px; text-align: center;\">State</th>\n                <th style=\"padding: 8px; text-align: center;\">Priority</th>\n            </tr>\n            <tr ng-repeat=\"(id, node) in msg.nodes\" style=\"border-bottom: 1px solid #222;\">\n                <td style=\"padding: 8px;\">{{node.name || id}}</td>\n                <td style=\"padding: 8px; text-align: center;\" ng-style=\"{'color': node.last_power > 100 ? '#ff6464' : '#00ff88'}\">{{node.last_power | number:1}}W</td>\n                <td style=\"padding: 8px; text-align: center;\">{{node.last_state}}</td>\n                <td style=\"padding: 8px; text-align: center;\">\n                    <span ng-style=\"{'background': node.priority === 'PHANTOM' ? '#ff6464' : node.priority === 'LUXURY' ? '#ff9500' : node.priority === 'SHIFTABLE' ? '#0096ff' : '#00ff88', 'padding': '3px 8px', 'border-radius': '4px', 'font-size': '11px'}\">{{node.priority}}</span>\n                </td>\n            </tr>\n        </table>\n    </div>\n    \n    <div ng-if=\"msg.optimalWindow\" style=\"background: rgba(0,255,136,0.1); padding: 15px; border-radius: 10px;\">\n        <h3 style=\"color: #00ff88; margin: 0 0 10px 0;\">🌞 Optimal Window</h3>\n        <div style=\"font-size: 13px;\">\n            {{msg.optimalWindow.start_time | date:'MMM d, HH:mm'}} - {{msg.optimalWindow.end_time | date:'HH:mm'}}\n            <span style=\"color: #888; margin-left: 10px;\">{{msg.optimalWindow.predicted_yield_wh}}Wh predicted</span>\n        </div>\n    </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "x": 570,
        "y": 80,
        "wires": []
    },

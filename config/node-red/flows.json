    {
        "id": "mqtt_broker_local",
        "type": "mqtt-broker",
        "name": "Local Mosquitto",
        "broker": "localhost",
        "port": "1883",
        "clientid": "nodered-guard",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "4",
        "keepalive": "60",
        "cleansession": true,
        "birthTopic": "home/nodered/status",
        "birthQos": "0",
        "birthPayload": "online",
        "closeTopic": "home/nodered/status",
        "closeQos": "0",
        "closePayload": "offline",
        "willTopic": "home/nodered/status",
        "willQos": "0",
        "willPayload": "offline"
    },

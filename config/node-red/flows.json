        "qos": "0",
        "retain": "false",
        "broker": "mqtt_broker_local",
        "x": 350,
        "y": 100,
        "wires": []
    },
    {
        "id": "mqtt_in_hermes_outbox",
        "type": "mqtt in",
        "z": "flow_hermes_chat",
        "name": "Hermes Outbox",
        "topic": "solar/hermes/outbox",
        "qos": "0",
        "datatype": "auto",
        "broker": "mqtt_broker_local",
        "x": 130,
        "y": 180,
        "wires": [["ui_text_hermes_reply"]]
    },
    {
        "id": "ui_text_hermes_reply",
        "type": "ui_text",
        "z": "flow_hermes_chat",
        "group": "ui_group_hermes_chat",
        "order": 2,
        "width": "12",
        "height": "8",
        "name": "Hermes Reply",
        "label": "",
        "format": "<div ng-bind-html=\"msg.payload.response || msg.payload\"></div>",
        "layout": "col-center",
        "className": "",
        "x": 350,
        "y": 180,
        "wires": []
    }
]

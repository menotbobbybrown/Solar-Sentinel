        "type": "ui_group",
        "name": "Decision Log",
        "tab": "ui_tab_dashboard",
        "order": 4,
        "disp": true,
        "width": "12",
        "collapse": false
    },
    {
        "id": "mqtt_in_alerts",
        "type": "mqtt in",
        "z": "flow_decision_log",
        "name": "Alerts In",
        "topic": "home/alerts/energy_guard",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt_broker_local",
        "x": 110,
        "y": 80,
        "wires": [["function_log_process"]]
    },
    {
        "id": "function_log_process",
        "type": "function",
        "z": "flow_decision_log",
        "name": "Log Accumulator",
        "func": "var log = context.get('log') || [];\nlog.unshift(msg.payload);\nif (log.length > 20) log.pop();\ncontext.set('log', log);\nmsg.payload = log;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 310,
        "y": 80,
        "wires": [["ui_table_log"]]
    },
    {
        "id": "ui_table_log",
        "type": "ui_table",
        "z": "flow_decision_log",
        "group": "ui_group_log",
        "name": "Decision Table",
        "order": 1,
        "width": 0,
        "height": 0,
        "columns": [\n    { \"field\": \"timestamp\", \"title\": \"Time\", \"width\": \"30%\", \"align\": \"left\", \"formatter\": \"datetime\", \"format\": \"HH:mm:ss\" },\n    { \"field\": \"message\", \"title\": \"Message\", \"width\": \"70%\", \"align\": \"left\", \"formatter\": \"plaintext\" }\n],\n        "outputs": 0,
        "cts": false,
        "x": 530,
        "y": 80,
        "wires": []
    }

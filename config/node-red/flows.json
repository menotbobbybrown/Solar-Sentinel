    {
        "id": "hermes_history_add",
        "type": "function",
        "z": "flow_hermes_chat",
        "name": "Add to History",
        "func": "// Simple in-memory history (would use context in production)\nif (!flow.get('hermesHistory')) {\n    flow.set('hermesHistory', []);\n}\nlet history = flow.get('hermesHistory');\nhistory.push({\n    timestamp: new Date().toISOString(),\n    response: msg.payload.response || msg.payload\n});\n// Keep last 10\nif (history.length > 10) history.shift();\nflow.set('hermesHistory', history);\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "x": 350,
        "y": 260,
        "wires": []
    },
    {

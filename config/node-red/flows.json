    {
        "id": "mqtt_in_eva_map_device",
        "type": "mqtt in",
        "z": "flow_device_manager",
        "name": "EVA Map",
        "topic": "solar/eva/map",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt_broker_local",
        "x": 160,
        "y": 760,
        "wires": [["device_list_processor"]]
    },
    {
        "id": "device_list_processor",
        "type": "function",
        "z": "flow_device_manager",
        "name": "Device List",
        "func": "// Create device list from map\nconst nodes = msg.payload.nodes || {};\nconst devices = Object.entries(nodes).map(([id, data]) => ({\n    id: id,\n    name: data.name || id,\n    priority: data.priority || 'UNKNOWN',\n    power: data.last_power || 0,\n    state: data.last_state || 'UNKNOWN'\n}));\nmsg.payload = devices;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "x": 380,
        "y": 760,
        "wires": [["ui_template_device_list"]]
    },
    {
        "id": "ui_template_device_list",
        "type": "ui_template",
        "z": "flow_device_manager",
        "group": "ui_group_device_list",
        "name": "Device List",
        "order": 1,
        "width": 12,
        "height": 6,
        "format": "<div style=\"background: #1a1a2e; padding: 15px; border-radius: 10px; max-height: 300px; overflow-y: auto;\">\n    <h4 style=\"color: #eee; margin: 0 0 15px 0;\">Device Registry</h4>\n    <table style=\"width: 100%; font-size: 12px;\">\n        <tr style=\"border-bottom: 1px solid #333;\">\n            <th>Name</th><th>Priority</th><th>Power</th><th>State</th>\n        </tr>\n        <tr ng-repeat=\"device in msg.payload\" style=\"border-bottom: 1px solid #222;\">\n            <td>{{device.name}}</td>\n            <td><span ng-style=\"{'color': device.priority === 'PHANTOM' ? '#ff6464' : device.priority === 'LUXURY' ? '#ff9500' : device.priority === 'SHIFTABLE' ? '#0096ff' : '#00ff88'}\">{{device.priority}}</span></td>\n            <td>{{device.power | number:1}}W</td>\n            <td>{{device.state}}</td>\n        </tr>\n    </table>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "x": 600,
        "y": 760,
        "wires": []
    }
